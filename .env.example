# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/truvornex_db

# Security Secrets
SESSION_SECRET=your_session_secret_here
TRUST_PASSPORT_SECRET=your_trust_passport_secret_here
SIMON_SYSTEM_TOKEN=your_simon_system_token_here
MFA_ENCRYPTION_KEY=your_mfa_encryption_key_here

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# AI Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Environment
NODE_ENV=development

# Server Configuration
PORT=5000

# Payment Gateway (Optional)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Firebase Authentication
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
